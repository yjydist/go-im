# Copy this file to .env and fill in your secrets.
# DO NOT commit .env to version control.

# MySQL root password (used by docker-compose for MySQL container and Go services)
MYSQL_ROOT_PASSWORD=your_mysql_password_here

# JWT signing secret (used by API server and WS server)
JWT_SECRET=your_jwt_secret_here

# Internal push API key (used between push server and WS server)
INTERNAL_API_KEY=your_internal_api_key_here
